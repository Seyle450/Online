Options -Indexes
RewriteEngine On

# Subdomains für Konzept-Projekte (saubere URLs)
# hevis.elyesferchichi.com → /Webdesign Agentur/hevis/
# bens.elyesferchichi.com  → /Webdesign Agentur/bens/
# usw. — wird über IONOS Control Panel gesteuert

# Weiterleitungen für alte GitHub-Pages-Pfade falls jemand die direkt aufgerufen hat
RewriteCond %{HTTP_HOST} ^elyesferchichi\.com$ [NC]
RewriteRule ^Webdesign-Agentur/antepli-baklava(/.*)?$ https://antepli.elyesferchichi.com$1 [R=301,L]
RewriteRule ^Webdesign-Agentur/hevis(/.*)?$ https://hevis.elyesferchichi.com$1 [R=301,L]
RewriteRule ^Webdesign-Agentur/bens(/.*)?$ https://bens.elyesferchichi.com$1 [R=301,L]
RewriteRule ^Webdesign-Agentur/lokma-lovers(/.*)?$ https://lokma.elyesferchichi.com$1 [R=301,L]
RewriteRule ^Webdesign-Agentur/cafe-niki(/.*)?$ https://niki.elyesferchichi.com$1 [R=301,L]

# webdesign-bremen/ → root (subdomain wurde gelöscht)
RewriteRule ^webdesign-bremen(/.*)?$ https://elyesferchichi.com$1 [R=301,L]
